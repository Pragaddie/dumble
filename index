<script>
  // ─── Inject photos ───
  const IMG1_DATA = "";
  const IMG2_DATA = "";

  document.getElementById('photo1').src = 'data:image/png;base64,' + IMG1_DATA;
  document.getElementById('photo2').src = 'data:image/png;base64,' + IMG2_DATA;

  // ─── State ───
  let startX = 0, startY = 0, currX = 0, currY = 0;
  let isDragging = false;
  let currentPhoto = 0; // 0 = photo1, 1 = photo2
  let decided = false;

  const card = document.getElementById('card-front');
  const overlayNope = document.getElementById('overlay-nope');
  const overlayLike = document.getElementById('overlay-like');
  const hint = document.getElementById('swipe-hint');
  const resultPage = document.getElementById('result-page');

  // Show hint briefly
  setTimeout(() => hint.classList.add('show'), 1200);
  setTimeout(() => hint.classList.remove('show'), 3500);

  // ─── Photo tap to switch ───
  card.addEventListener('click', (e) => {
    if (Math.abs(currX - startX) > 5) return; // was dragging
    const rect = card.getBoundingClientRect();
    const tapX = e.clientX - rect.left;
    if (tapX > rect.width / 2) {
      // next photo
      if (currentPhoto === 0) switchPhoto(1);
    } else {
      if (currentPhoto === 1) switchPhoto(0);
    }
  });

  function switchPhoto(idx) {
    currentPhoto = idx;
    const p1 = document.getElementById('photo1');
    const dots = card.querySelectorAll('.photo-dot');
    if (idx === 0) {
      p1.src = 'data:image/png;base64,' + IMG1_DATA;
      dots[0].classList.add('active');
      dots[1].classList.remove('active');
    } else {
      p1.src = 'data:image/png;base64,' + IMG2_DATA;
      dots[1].classList.add('active');
      dots[0].classList.remove('active');
    }
  }

  // ─── Drag Logic ───
  function getCoords(e) {
    return e.touches ? { x: e.touches[0].clientX, y: e.touches[0].clientY }
                     : { x: e.clientX, y: e.clientY };
  }

  function onStart(e) {
    if (decided) return;
    const c = getCoords(e);
    startX = currX = c.x;
    startY = currY = c.y;
    isDragging = true;
    card.style.transition = 'none';
  }

  const firebaseConfig = {
    apiKey: "AIzaSyCekk4Irh-n2akYQtHchovYQCe7vdyrrpA",
    authDomain: "swipee-6e1e4.firebaseapp.com",
    projectId: "swipee-6e1e4",
    storageBucket: "swipee-6e1e4.firebasestorage.app",
    messagingSenderId: "577508749888",
    appId: "1:577508749888:web:0418afd15945abb0ec65a5",
    measurementId: "G-X12X5CN64C"
  };

  firebase.initializeApp(firebaseConfig);
  const db = firebase.firestore();
  const TRACKER_ID = 'praggie_nimrit';

  async function recordSwipe(action) {
    const payload = {
      person: 'Nimrit',
      action,
      actionLabel: action === 'right' ? 'Swiped Right' : 'Swiped Left',
      profileName: 'Praggie',
      recordedAt: new Date().toLocaleString(),
      recordedAtISO: new Date().toISOString(),
      trackerId: TRACKER_ID,
      updatedAt: firebase.firestore.FieldValue.serverTimestamp()
    };

    try {
      await db.collection('dumble_swipes').doc(TRACKER_ID).set(payload, { merge: true });
      return true;
    } catch (error) {
      console.error('Failed to record swipe:', error);
      return false;
    }
  }

  function onMove(e) {
    if (!isDragging) return;
    e.preventDefault();
    const c = getCoords(e);
    currX = c.x;
    currY = c.y;
    const dx = currX - startX;
    const dy = currY - startY;
    const rot = dx * 0.07;

    card.style.transform = `translate(${dx}px, ${dy * 0.4}px) rotate(${rot}deg)`;

    const threshold = 60;
    const progress = Math.min(Math.abs(dx) / 120, 1);

    if (dx < -threshold) {
      overlayNope.style.opacity = progress.toFixed(2);
      overlayLike.style.opacity = 0;
    } else if (dx > threshold) {
      overlayLike.style.opacity = progress.toFixed(2);
      overlayNope.style.opacity = 0;
    } else {
      overlayNope.style.opacity = 0;
      overlayLike.style.opacity = 0;
    }
  }

  function onEnd() {
    if (!isDragging) return;
    isDragging = false;
    const dx = currX - startX;

    card.style.transition = 'transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94)';

    if (dx < -100) {
      // NOPE
      flyOut('left');
    } else if (dx > 100) {
      // LIKE
      flyOut('right');
    } else {
      // Snap back
      card.style.transform = '';
      overlayNope.style.opacity = 0;
      overlayLike.style.opacity = 0;
    }
  }

  function flyOut(dir) {
    decided = true;
    const x = dir === 'left' ? -500 : 500;
    card.style.transition = 'transform 0.5s cubic-bezier(0.55, 0, 1, 0.45)';
    card.style.transform = `translate(${x}px, 60px) rotate(${dir === 'left' ? -25 : 25}deg)`;

    setTimeout(() => showResult(dir === 'right'), 500);
  }

  async function showResult(liked) {
    const page = document.getElementById('result-page');
    const emoji = document.getElementById('result-emoji');
    const title = document.getElementById('result-title');
    const sub = document.getElementById('result-subtitle');
    const badge = document.getElementById('result-badge-text');

    page.className = liked ? 'liked' : 'noped';

    if (liked) {
      const recorded = await recordSwipe('right');
      emoji.textContent = '💛';
      title.textContent = "It's a Match, Nimrit!";
      sub.textContent = recorded
        ? 'Nimrit, You clearly have good taste 😉'
        : 'Nimrit, You clearly have good taste 😉';
      badge.textContent = recorded ? 'Mutual right swipe' : 'Right swipe not synced';
    } else {
      emoji.textContent = '💔';
      title.textContent = 'Passed…';
      sub.textContent = "Praggie wasn't the one this time. But hey, He is very good though!";
      const recorded = await recordSwipe('left');
      badge.textContent = recorded ? 'Swipe recorded privately' : 'Swipe not synced';
    }

    page.style.display = 'flex';
  }

  document.getElementById('btn-nope').addEventListener('click', () => {
    if (decided) return;
    overlayNope.style.opacity = 1;
    flyOut('left');
  });

  document.getElementById('btn-like').addEventListener('click', () => {
    if (decided) return;
    overlayLike.style.opacity = 1;
    flyOut('right');
  });

  document.getElementById('restart-btn').addEventListener('click', () => {
    decided = false;
    currentPhoto = 0;

    // Reset card
    card.style.transition = 'none';
    card.style.transform = '';
    overlayNope.style.opacity = 0;
    overlayLike.style.opacity = 0;
    document.getElementById('photo1').src = 'data:image/png;base64,' + IMG1_DATA;

    const dots = card.querySelectorAll('.photo-dot');
    dots[0].classList.add('active');
    dots[1].classList.remove('active');

    resultPage.style.display = 'none';

    setTimeout(() => card.style.transition = '', 50);
  });

  // Pointer events
  card.addEventListener('mousedown', onStart);
  card.addEventListener('mousemove', onMove);
  card.addEventListener('mouseup', onEnd);
  card.addEventListener('mouseleave', onEnd);
  card.addEventListener('touchstart', onStart, { passive: false });
  card.addEventListener('touchmove', onMove, { passive: false });
  card.addEventListener('touchend', onEnd);
</script>
</body>
</html>
