<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>dumble ✦ praggie</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Caveat:wght@400;600;700&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap');

  * { margin: 0; padding: 0; box-sizing: border-box; }

  :root {
    --bumble-yellow: #FFC629;
    --bumble-dark: #1A1A1A;
    --bumble-cream: #FFF9F0;
    --bumble-warm: #F5ECD7;
    --bumble-gray: #888;
    --card-shadow: 0 20px 60px rgba(0,0,0,0.18);
    --swipe-radius: 20px;
  }

  html, body {
    height: 100%;
    overflow: hidden;
    background: var(--bumble-cream);
    font-family: 'DM Sans', sans-serif;
  }

  /* ─── APP SHELL ─── */
  #app {
    height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    max-width: 430px;
    margin: 0 auto;
    position: relative;
  }

  /* ─── HEADER ─── */
  #header {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 20px 8px;
    z-index: 10;
  }

  .logo-wrap {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .bee-doodle svg {
    width: 38px;
    height: 38px;
  }

  .bumble-text {
    font-family: 'Caveat', cursive;
    font-size: 28px;
    font-weight: 700;
    color: var(--bumble-dark);
    letter-spacing: -0.5px;
    position: relative;
  }

  .bumble-text::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 100%;
    height: 2.5px;
    background: var(--bumble-yellow);
    border-radius: 2px;
    transform: rotate(-1deg);
  }

  .header-icons {
    display: flex;
    gap: 14px;
    align-items: center;
  }

  .header-icon {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: white;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    cursor: pointer;
    transition: transform 0.15s;
  }
  .header-icon:hover { transform: scale(1.08); }

  /* ─── CARD STACK AREA ─── */
  #card-area {
    flex: 1;
    width: 100%;
    padding: 8px 16px 0;
    position: relative;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    overflow: hidden;
  }

  /* ─── SWIPE CARD ─── */
  .swipe-card {
    position: absolute;
    width: calc(100% - 32px);
    height: min(540px, 75vh);
    border-radius: var(--swipe-radius);
    overflow: hidden;
    box-shadow: var(--card-shadow);
    cursor: grab;
    user-select: none;
    touch-action: none;
    transition: transform 0.05s;
    will-change: transform;
    background: #111;
  }

  .swipe-card:active { cursor: grabbing; }

  /* Back card (slightly visible behind) */
  .swipe-card.back {
    transform: scale(0.96) translateY(10px);
    z-index: 1;
    pointer-events: none;
  }
  .swipe-card.front {
    z-index: 2;
  }

  /* Card photo */
  .card-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  /* Gradient overlay */
  .card-gradient {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 65%;
    background: linear-gradient(to top, rgba(0,0,0,0.88) 0%, rgba(0,0,0,0.4) 55%, transparent 100%);
    pointer-events: none;
  }

  /* Card info */
  .card-info {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 20px 22px 22px;
    color: white;
  }

  .card-name-row {
    display: flex;
    align-items: baseline;
    gap: 10px;
    margin-bottom: 4px;
  }

  .card-name {
    font-size: 28px;
    font-weight: 500;
    letter-spacing: -0.3px;
  }

  .card-age {
    font-size: 22px;
    font-weight: 300;
    opacity: 0.9;
  }

  .card-location {
    font-size: 13px;
    opacity: 0.7;
    display: flex;
    align-items: center;
    gap: 4px;
    margin-bottom: 10px;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 10px;
  }

  .card-tag {
    background: rgba(255,255,255,0.15);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 20px;
    padding: 4px 10px;
    font-size: 11px;
    letter-spacing: 0.3px;
  }

  .card-bio {
    font-size: 12.5px;
    line-height: 1.55;
    opacity: 0.85;
    font-weight: 300;
    max-height: 52px;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
  }

  /* Photo dots indicator */
  .photo-dots {
    position: absolute;
    top: 12px;
    left: 0;
    right: 0;
    display: flex;
    gap: 5px;
    justify-content: center;
    pointer-events: none;
  }

  .photo-dot {
    height: 3px;
    border-radius: 2px;
    background: rgba(255,255,255,0.4);
    transition: all 0.3s;
    flex: 1;
    max-width: 50px;
  }
  .photo-dot.active {
    background: white;
  }

  /* Swipe decision overlays */
  .swipe-overlay {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.15s;
    pointer-events: none;
    z-index: 10;
  }

  .swipe-overlay.nope {
    background: linear-gradient(135deg, rgba(255,60,60,0.25), transparent);
  }
  .swipe-overlay.like {
    background: linear-gradient(225deg, rgba(100,230,100,0.25), transparent);
  }

  .swipe-label {
    font-family: 'Caveat', cursive;
    font-size: 52px;
    font-weight: 700;
    border: 4px solid;
    border-radius: 10px;
    padding: 6px 18px;
    transform: rotate(-8deg);
    letter-spacing: 2px;
  }

  .swipe-label.nope {
    color: #ff4444;
    border-color: #ff4444;
  }
  .swipe-label.like {
    color: #3DD883;
    border-color: #3DD883;
    transform: rotate(8deg);
  }

  /* ─── BOTTOM ACTIONS ─── */
  #action-bar {
    width: 100%;
    padding: 14px 16px 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 18px;
  }

  .action-btn {
    border: none;
    background: white;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 16px rgba(0,0,0,0.12);
    transition: all 0.2s;
    position: relative;
  }

  .action-btn:hover {
    transform: scale(1.1);
    box-shadow: 0 6px 24px rgba(0,0,0,0.18);
  }

  .action-btn:active {
    transform: scale(0.96);
  }

  .btn-nope {
    width: 58px;
    height: 58px;
  }

  .btn-like {
    width: 70px;
    height: 70px;
    background: var(--bumble-yellow) !important;
  }

  .btn-star {
    width: 50px;
    height: 50px;
  }

  /* ─── RESULT PAGE ─── */
  #result-page {
    display: none;
    position: fixed;
    inset: 0;
    background: var(--bumble-cream);
    z-index: 100;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 40px 30px;
    text-align: center;
    animation: fadeIn 0.5s ease;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: scale(0.95); }
    to { opacity: 1; transform: scale(1); }
  }

  @keyframes floatUp {
    0% { transform: translateY(30px); opacity: 0; }
    100% { transform: translateY(0); opacity: 1; }
  }

  .result-emoji {
    font-size: 90px;
    margin-bottom: 18px;
    animation: floatUp 0.6s 0.1s ease both;
  }

  .result-title {
    font-family: 'Caveat', cursive;
    font-size: 42px;
    font-weight: 700;
    color: var(--bumble-dark);
    margin-bottom: 10px;
    animation: floatUp 0.6s 0.2s ease both;
  }

  .result-subtitle {
    font-size: 15px;
    color: var(--bumble-gray);
    line-height: 1.6;
    max-width: 280px;
    animation: floatUp 0.6s 0.3s ease both;
    margin-bottom: 32px;
  }

  .result-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: white;
    border-radius: 50px;
    padding: 10px 22px;
    font-size: 14px;
    font-weight: 500;
    box-shadow: 0 4px 20px rgba(0,0,0,0.1);
    margin-bottom: 32px;
    animation: floatUp 0.6s 0.35s ease both;
  }

  .restart-btn {
    background: var(--bumble-yellow);
    color: var(--bumble-dark);
    border: none;
    border-radius: 50px;
    padding: 16px 40px;
    font-size: 16px;
    font-weight: 500;
    cursor: pointer;
    font-family: 'DM Sans', sans-serif;
    letter-spacing: 0.2px;
    box-shadow: 0 6px 24px rgba(255,198,41,0.4);
    transition: all 0.2s;
    animation: floatUp 0.6s 0.4s ease both;
  }

  .restart-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 30px rgba(255,198,41,0.5);
  }

  .restart-btn:active {
    transform: scale(0.97);
  }

  /* Result variants */
  #result-page.liked .result-title { color: #2da55a; }
  #result-page.noped .result-title { color: #e03030; }

  /* ─── BOTTOM NAV ─── */
  #bottom-nav {
    width: 100%;
    display: flex;
    justify-content: space-around;
    padding: 0 10px 8px;
    border-top: 1px solid rgba(0,0,0,0.06);
  }

  .nav-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3px;
    padding: 8px 12px;
    cursor: pointer;
    opacity: 0.4;
    font-size: 10px;
    color: var(--bumble-dark);
    font-weight: 500;
  }
  .nav-item.active { opacity: 1; }
  .nav-item svg { width: 22px; height: 22px; }

  /* ─── TOAST SWIPE INDICATOR ─── */
  .swipe-hint {
    position: absolute;
    bottom: 90px;
    left: 50%;
    transform: translateX(-50%);
    background: rgba(0,0,0,0.65);
    color: white;
    font-family: 'Caveat', cursive;
    font-size: 16px;
    padding: 8px 20px;
    border-radius: 20px;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.4s;
    white-space: nowrap;
    z-index: 20;
  }

  .swipe-hint.show { opacity: 1; }


  .status-note {
    margin-top: 10px;
    font-size: 12px;
    line-height: 1.5;
    color: var(--bumble-gray);
    max-width: 300px;
  }

  /* Media for taller phones */
  @media (min-height: 780px) {
    .swipe-card { height: min(600px, 78vh); }
  }
</style>

<script src="https://www.gstatic.com/firebasejs/10.12.5/firebase-app-compat.js"></script>
